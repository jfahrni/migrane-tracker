DATABASE_URL="file:/app/data/prod.db"

# MCP-Authentifizierung
# Statischer Bearer-Token für Claude Desktop
MCP_TOKEN="dein-geheimer-token-hier"
ENABLE_MCP="true"

# ── Web-Login (Dashboard + OAuth-Consent) ────────────────────────────────────
# Schützt die Weboberfläche und den OAuth-Zustimmungsdialog (Claude Mobile).
AUTH_USERNAME="jonas"

# scrypt-Hash des Passworts (NIE das Klartext-Passwort ablegen). Generieren mit:
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log('scrypt:'+s+':'+c.scryptSync(process.argv[1],s,64).toString('hex'))" 'DEIN-PASSWORT'
AUTH_PASSWORD_HASH="scrypt:<saltHex>:<hashHex>"

# Signierschlüssel für das Session-Cookie (min. 32 Byte). Generieren mit:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="<zufaelliger-hex-string>"

# Wetterdaten (Schaffhausen ist Standard, kann überschrieben werden)
WEATHER_LAT="47.6958"
WEATHER_LON="8.6353"

# Optional: Seed-Fallback für das Medikamenten-Startdatum (YYYY-MM-DD).
# Wird nur einmalig in die Medication-Tabelle übernommen, wenn diese leer ist.
# Danach ist die Tabelle maßgeblich (Tool: set_medication / list_medications).
CANDESARTAN_START_DATE="2026-06-01"

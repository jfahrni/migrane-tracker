DATABASE_URL="file:/app/data/prod.db"

# MCP-Authentifizierung
# Statischer Bearer-Token für Claude Desktop
MCP_TOKEN="dein-geheimer-token-hier"
ENABLE_MCP="true"

# PIN für den OAuth-Consent-Dialog (Claude Mobile)
MCP_CONSENT_PIN="1234"

# Wetterdaten (Schaffhausen ist Standard, kann überschrieben werden)
WEATHER_LAT="47.6958"
WEATHER_LON="8.6353"

# Optional: Seed-Fallback für das Medikamenten-Startdatum (YYYY-MM-DD).
# Wird nur einmalig in die Medication-Tabelle übernommen, wenn diese leer ist.
# Danach ist die Tabelle maßgeblich (Tool: set_medication / list_medications).
CANDESARTAN_START_DATE="2026-06-01"

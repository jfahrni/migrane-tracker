generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Attack {
  id             String    @id @default(cuid())
  startedAt      DateTime
  endedAt        DateTime?
  intensity      Int?      // Kopfschmerz-Intensität 0-10 NRS (0 = schmerzfrei)
  auraSeverity   Int?      // Aura-Ausprägung 1-3 (leicht/mittel/stark), entkoppelt vom Schmerz
  hasAura        Boolean?
  auraType       String?   // "visual" | "sensory" | "speech" | "other"
  hadPostdrome   Boolean?  // Postdrome ("Matschbirne") als auswertbares Flag
  postdromeNotes String?   // optionaler Freitext zur Postdrome
  triggers       String    @default("[]") // JSON string array of trigger slugs
  notes          String?
  medications    String?
  weather        String?   // JSON snapshot from OpenMeteo
  episodeGroupId String?   // gruppiert Schübe desselben Tages (mehrere Schübe = eine Episode)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([startedAt(sort: Desc)])
  @@index([episodeGroupId])
}

// Freie Anamnese / Vorgeschichte — der Kontext, der die Attacken-Daten erst
// interpretierbar macht (Vorbefunde, Bildgebung, relevante Ereignisse wie TGA,
// Komorbiditäten). Wird in get_overview mitgeliefert, damit der Kontext in JEDER
// Unterhaltung präsent ist und nicht nur auf explizite Nachfrage.
// Getrennte Typen statt einer Freitext-Note: der Typ entscheidet, ob ein Eintrag
// beim Auswerten überhaupt gelesen/gewichtet wird.
model HistoryEntry {
  id          String    @id @default(cuid())
  type        String    // ONSET | PRIOR_PATTERN | IMAGING | DIAGNOSIS | COMORBID_EVENT | MEDICATION_PAST | FAMILY | CARE_CONTEXT | OTHER
  title       String    // kurz, z.B. "MRT Schädel", "TGA-Episode"
  detail      String?   // Befund, Verlauf, klinischer Kontext
  occurredAt  DateTime? // nullable — Zeitpunkt wird nicht erzwungen
  precision   String?   // YEAR | MONTH | DAY — verhindert, dass ein Näherungswert später wie ein Fakt aussieht
  approximate Boolean   @default(false) // true = Datum ist geschätzt, nicht belegt
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([occurredAt(sort: Desc)])
  @@index([type])
}

// Key/Value für dauerhafte Einstellungen. Trägt u.a. die "standingInstructions",
// die bei JEDEM get_overview zuoberst ausgeliefert werden (Pflichtfeld statt Selbstdisziplin).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Medikamenten-Phasen — löst das lose CANDESARTAN_START_DATE aus der Env ab.
// Erlaubt "Tag N"-Berechnung und mehrere Präparate über die Zeit.
model Medication {
  id        String    @id @default(cuid())
  name      String
  startedAt DateTime
  // Ohne diese beiden sieht ein hingeschriebenes 01.01.2020 in sechs Monaten wie ein Fakt aus.
  startPrecision   String?  // YEAR | MONTH | DAY
  startApproximate Boolean  @default(false)
  endedAt   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([startedAt(sort: Desc)])
}

// ── OAuth 2.0 (für Claude Mobile) ────────────────────────────────────────────

model OAuthClient {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientName   String
  redirectUris String   // JSON array
  createdAt    DateTime @default(now())

  codes         OAuthCode[]
  tokens        OAuthToken[]
  refreshTokens OAuthRefreshToken[]
}

model OAuthCode {
  id                  String      @id @default(cuid())
  code                String      @unique
  clientId            String
  client              OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  redirectUri         String
  scopes              String
  codeChallenge       String
  codeChallengeMethod String      @default("S256")
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime    @default(now())

  @@index([code])
  @@index([expiresAt])
}

model OAuthToken {
  id        String      @id @default(cuid())
  tokenHash String      @unique
  clientId  String
  client    OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  scopes    String
  expiresAt DateTime
  createdAt DateTime    @default(now())

  @@index([tokenHash])
  @@index([expiresAt])
}

model OAuthRefreshToken {
  id        String      @id @default(cuid())
  tokenHash String      @unique
  clientId  String
  client    OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  scopes    String
  expiresAt DateTime
  createdAt DateTime    @default(now())

  @@index([tokenHash])
  @@index([expiresAt])
}

model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime
}
